{
  "name": "enlacevrc-bot",
  "version": "1.0.0",
  "description": "Discord bot that links Discord accounts to VRChat profiles and manages VRChat group membership.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "deploy-commands": "tsx scripts/deploy-commands.ts",
    "deploy-commands:global": "tsx scripts/deploy-commands.ts --global",
    "clear-global-commands": "tsx scripts/clear-global-commands.ts",
    "login": "tsx scripts/login.ts",
    "adduser": "tsx scripts/adduser.ts",
    "getuser": "tsx scripts/getuser.ts",
    "deluser": "tsx scripts/deluser.ts",
    "delgroup": "tsx scripts/delgroup.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^17.2.2",
    "keyv": "^5.5.2",
    "keyv-file": "^5.2.0",
    "node-cache": "^5.1.2",
    "vrchat": "^2.20.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.31.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  }
}
